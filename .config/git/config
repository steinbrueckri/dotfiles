[core]
    excludesfile = ~/.config/git/ignore
    pager = delta
    editor = nvim
    ignorecase = true

[delta]
    line-numbers = true
    side-by-side = true

[credential]
    helper = osxkeychain

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[fetch]
    prune = true
    pruneTags = true

[push]
    default = simple
    autoSetupRemote = true
    followTags = true

[pull]
    rebase = true

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[commit]
    gpgsign = true
    template = ~/.config/git/msg
    verbose = true

[gpg]
    format = ssh

[gpg "ssh"]
    program = ssh-keygen
    allowedSignersFile = ~/.config/git/allowed_signers

[user]
    name = Richard Steinbrueck
    email = richard.steinbrueck@userlike.com
    signingkey = key::ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIO/sst8BMRFYKTsauFOOlVNJ3kJf5oQT6nrWharQyYnh

[alias]
    branchf = "!git branch --sort=-committerdate | grep -v '^\\*' | fzf --reverse --info=inline | xargs git switch"
    switchf = "!git branch --sort=-committerdate | grep -v '^\\*' | fzf --reverse --info=inline | xargs git switch"
    nevermind = !git reset --hard HEAD && git clean -d -f
    l = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
    clone-for-worktrees = !sh "$HOME/bin/git-clone-bare-for-worktrees.sh"
    graph = log --all --graph --decorate --oneline
    ignore = !gi() { local IFS=','; curl -sL "https://www.toptal.com/developers/gitignore/api/$*"; }; gi

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = -version:refname

[init]
    defaultBranch = main

[diff]
    algorithm = histogram
    colorMoved = plain
    mnemonicPrefix = true
    renames = true

[help]
    autocorrect = prompt

[interactive]
    diffFilter = delta --color-only

[merge]
    tool = ec
    conflictstyle = zdiff3

[mergetool]
    prompt = false
    keepBackup = false

[mergetool "ec"]
    cmd = ec "$BASE" "$LOCAL" "$REMOTE" "$MERGED"
    trustExitCode = true

[diff "ansible-vault"]
    textconv = ansible-vault view
    cachetextconv = false

[merge "ansible-vault"]
    name = ansible-vault merge driver
    driver = /usr/local/bin/ansible-vault-merge -- %O %A %B %P

[rerere]
    enabled = true
    autoUpdate = true

[maintenance]
    auto = true
    strategy = incremental

[status]
    branch = true

[includeIf "gitdir:/Users/richardsteinbrueck/Projects/"]
    path = ~/.config/git/config-private

[includeIf "gitdir:/Users/richardsteinbrueck/Projects/pixel-combo/"]
    path = ~/.config/git/config-pixelcombo
